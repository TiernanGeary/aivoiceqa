# voiceaiqa configuration
# Copy to .env and fill in values

# --- Mock mode (set false for real calls) ---
RECO_MOCK_MODE=false

# --- Reco / realtime-tmp connection ---
RECO_API_URL=http://localhost:3010
# Login credentials for realtime-tmp (used to auto-obtain JWT)
RECO_API_USERNAME=your-reco-username
RECO_API_PASSWORD=your-reco-password
# Or set a static JWT directly (leave blank if using username/password above)
RECO_API_TOKEN=

# --- Twilio (for receiving real calls from reco) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# The Twilio number reco will dial (E.164 format)
TWILIO_PHONE_NUMBER=+81...
QA_SERVER_PORT=8050

# --- Public URL for Twilio webhook ---
# Your public HTTPS hostname (e.g. ngrok URL, no trailing slash, no https://)
# Example: abc123.ngrok-free.app
QA_PUBLIC_URL=your-ngrok-hostname.ngrok-free.app

# --- Cartesia TTS (for generating user audio responses) ---
CARTESIA_API_KEY=...
CARTESIA_VOICE_ID=japanese-voice-id
AUDIO_CACHE_DIR=cache/audio

# --- Evaluation: Tier 2 (Claude grading) ---
ANTHROPIC_API_KEY=sk-ant-...
EVAL_MODEL=claude-sonnet-4-20250514
EVAL_TEMPERATURE=0

# --- Evaluation: Tier 3 (Whisper transcription, optional) ---
OPENAI_API_KEY=sk-...

# --- Thresholds ---
LATENCY_P95_THRESHOLD_MS=3000
DEAD_AIR_THRESHOLD_MS=5000
SCENARIO_STEP_TIMEOUT=60
CALL_WAIT_TIMEOUT=30
